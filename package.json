{
  "name": "cygnus-playwright-poc",
  "version": "1.0.0",
  "description": "Playwright automation for Cygnus Power BI dashboard",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:setup": "npx playwright test --project=setup",
    "main:run": "npx playwright test --project=main-run --reporter=list,html --no-deps --grep \"Cygnus Main Run\"",
    "compare:excel": "npx playwright test --project=compare-excel --reporter=list --no-deps",
    "parity": "node scripts/run-parity.js both",
    "parity:source": "node scripts/run-parity.js source",
    "parity:target": "node scripts/run-parity.js target",
    "show:report": "npx playwright show-report",
    "install-browsers": "npx playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "powerbi-client": "^2.23.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0"
  }
}
